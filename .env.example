# Bangumi OAuth
# 在 https://bgm.tv/dev/app 创建应用获取
VITE_BANGUMI_CLIENT_ID=your_bangumi_client_id
VITE_BANGUMI_CLIENT_SECRET=your_bangumi_client_secret

# GitHub OAuth
# 在 https://github.com/settings/developers 创建 OAuth App 获取
VITE_GITHUB_CLIENT_ID=your_github_client_id
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret
